@startuml
title "excaliplant — parser plugins"
package "engine" as engine {
  [runEngine] as runEngine
}
package "component plugins" as comp {
  [component.title] as component_title
  runEngine --> component_title
  [component.close] as component_close
  runEngine --> component_close
  [component.noteBlock] as component_noteBlock
  runEngine --> component_noteBlock
  [component.noteOf] as component_noteOf
  runEngine --> component_noteOf
  [component.noteFree] as component_noteFree
  runEngine --> component_noteFree
  [component.shapeKeyword] as component_shapeKeyword
  runEngine --> component_shapeKeyword
  [component.container] as component_container
  runEngine --> component_container
  [component.bracketBox] as component_bracketBox
  runEngine --> component_bracketBox
  [component.usecaseParens] as component_usecaseParens
  runEngine --> component_usecaseParens
  [component.connection] as component_connection
  runEngine --> component_connection
}
package "sequence plugins" as seq {
  [sequence.title] as sequence_title
  runEngine --> sequence_title
  [sequence.participant] as sequence_participant
  runEngine --> sequence_participant
  [sequence.noteSideBlock] as sequence_noteSideBlock
  runEngine --> sequence_noteSideBlock
  [sequence.noteOverBlock] as sequence_noteOverBlock
  runEngine --> sequence_noteOverBlock
  [sequence.noteSide] as sequence_noteSide
  runEngine --> sequence_noteSide
  [sequence.noteOver] as sequence_noteOver
  runEngine --> sequence_noteOver
  [sequence.message] as sequence_message
  runEngine --> sequence_message
}
@enduml