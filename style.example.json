    "family": "Excalifont",
    "sizeTitle": 18,
    "sizeDescription": 13,
    "sizeEdgeLabel": 10,
    "sizePlaneTitle": 22,
    "sizeSubplaneTitle": 16,
    "glyphRatio": 0.51,
    "lineHeight": 1.25,
    "minSize": 8
  },
