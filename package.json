{
  "name": "@grethel-labs/excaliplant",
  "version": "0.5.0",
  "description": "PlantUML → ELK layout → Excalidraw renderer with a plugin-based parser.",
  "type": "module",
  "main": "index.mjs",
  "bin": {
    "excaliplant": "bin/excaliplant.mjs"
  },
  "files": [
    "index.mjs",
    "bin/",
    "src/",
    "assets/fonts/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "exports": {
    ".": "./index.mjs",
    "./parser/plantuml": "./src/parser/plantuml.mjs",
    "./parser/engine": "./src/parser/engine.mjs",
    "./layout": "./src/layout/elk_layout.mjs",
    "./render": "./src/render/excalidraw.mjs",
    "./render/excalidraw": "./src/render/excalidraw.mjs",
    "./render/svg": "./src/render/svg.mjs",
    "./render/canvas-svg": "./src/render/canvas_svg.mjs",
    "./render/png": "./src/render/png.mjs",
    "./render/schema": "./src/render/schema.mjs",
    "./render/rng": "./src/render/rng.mjs",
    "./model": "./src/model/diagram.mjs",
    "./style": "./src/style/style.mjs"
  },
  "scripts": {
    "test": "node --test tests/edge_cases.test.mjs tests/functional_more.test.mjs tests/merge_driver.test.mjs tests/plantuml.test.mjs tests/security.test.mjs tests/self_introspection.test.mjs tests/style.test.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "build:docs": "node docs/scripts/build-docs.mjs",
    "build:api": "node docs/scripts/build-docs.mjs",
    "build": "npm run build:docs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky && node scripts/setup-merge-drivers.mjs",
    "prepublishOnly": "node scripts/prepublish-guard.mjs && npm test && npm run typecheck && npm run format:check && npm run build"
  },
  "lint-staged": {
    "*.{mjs,js,cjs,ts,json,yml,yaml,md}": "prettier --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grethel-labs/excaliplant.git"
  },
  "homepage": "https://github.com/grethel-labs/excaliplant",
  "bugs": "https://github.com/grethel-labs/excaliplant/issues",
  "keywords": [
    "plantuml",
    "excalidraw",
    "diagram",
    "elk",
    "renderer",
    "svg",
    "png",
    "uml",
    "sequence-diagram"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "elkjs": "^0.11.1",
    "roughjs": "^4.6.6"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nunjucks": "^3.2.4",
    "prettier": "^3.8.3",
    "tree-node-cli": "^3.0.0",
    "typescript": "^6.0.3"
  }
}
