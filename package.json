{
  "name": "@grethel-labs/excaliplant",
  "version": "0.9.0",
  "description": "PlantUML → ELK layout → Excalidraw renderer with a plugin-based parser.",
  "type": "module",
  "main": "index.mjs",
  "bin": {
    "excaliplant": "bin/excaliplant.mjs"
  },
  "files": [
    "index.mjs",
    "bin/",
    "src/",
    "assets/arrowheads/",
    "assets/fonts/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "exports": {
    ".": "./index.mjs",
    "./parser/plantuml": "./src/main/parser.mjs",
    "./parser/engine": "./src/util/parser_engine.mjs",
    "./layout": "./src/general/layout/elk_layout.mjs",
    "./render": "./src/general/render/excalidraw.mjs",
    "./render/excalidraw": "./src/general/render/excalidraw.mjs",
    "./render/svg": "./src/general/render/svg.mjs",
    "./render/canvas-svg": "./src/general/render/canvas_svg.mjs",
    "./render/png": "./src/general/render/png.mjs",
    "./render/schema": "./src/general/render/schema.mjs",
    "./render/rng": "./src/general/render/rng.mjs",
    "./diagrams": "./src/diagrams/index.mjs",
    "./diagrams/base": "./src/diagrams/base/index.mjs",
    "./main/parser": "./src/main/parser.mjs",
    "./main/pipeline": "./src/main/pipeline.mjs",
    "./main/registry": "./src/main/registry.mjs",
    "./modules": "./src/main/builtin.mjs",
    "./modules/diagrams": "./src/diagrams/index.mjs",
    "./modules/base": "./src/diagrams/base/index.mjs",
    "./modules/dependencies": "./src/main/dependencies.mjs",
    "./modules/registry": "./src/main/registry.mjs",
    "./modules/introspection": "./src/main/introspection.mjs",
    "./platform/security": "./src/general/platform/security_base.mjs",
    "./platform/diagnostics": "./src/general/platform/diagnostics.mjs",
    "./platform/assets": "./src/general/platform/asset_base.mjs",
    "./platform/services": "./src/general/platform/services.mjs",
    "./model": "./src/general/model/diagram.mjs",
    "./style": "./src/general/style/style.mjs"
  },
  "scripts": {
    "pretest": "node scripts/clean-test-output.mjs",
    "test": "node --test tests/edge_cases.test.mjs tests/functional_more.test.mjs tests/merge_driver.test.mjs tests/modular_architecture.test.mjs tests/plantuml.test.mjs tests/security.test.mjs tests/self_introspection.test.mjs tests/sequence_components.test.mjs tests/class_components.test.mjs tests/component_components.test.mjs tests/style.test.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "build:docs": "node docs/scripts/build-docs.mjs",
    "build:api": "node docs/scripts/build-docs.mjs",
    "build": "npm run test && npm run build:docs && npm run build:api && tsc -p tsconfig.json --emitDeclarationOnly",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky && node scripts/setup-merge-drivers.mjs",
    "prepublishOnly": "node scripts/prepublish-guard.mjs && npm test && npm run typecheck && npm run format:check && npm run build"
  },
  "lint-staged": {
    "*.{mjs,js,cjs,ts,json,yml,yaml,md}": "prettier --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grethel-labs/excaliplant.git"
  },
  "homepage": "https://github.com/grethel-labs/excaliplant",
  "bugs": "https://github.com/grethel-labs/excaliplant/issues",
  "keywords": [
    "plantuml",
    "excalidraw",
    "diagram",
    "elk",
    "renderer",
    "svg",
    "png",
    "uml",
    "javascript",
    "js",
    "sequence-diagram"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "elkjs": "^0.11.1",
    "roughjs": "^4.6.6"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nunjucks": "^3.2.4",
    "prettier": "^3.8.3",
    "tree-node-cli": "^3.0.0",
    "typescript": "^6.0.3"
  }
}
